# 13TMOS Environment Variables

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MCP Server (for Claude Desktop SSE transport)
MCP_API_KEY=your_mcp_api_key_here

# Bridge — production platform sync
TMOS13_REMOTE_URL=https://joyful-dream-production-792d.up.railway.app
TMOS13_REMOTE_KEY=your_production_api_key_here

# WhatsApp Channel — Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TMOS13_WHATSAPP_PACK=guest

# Telegram Channel
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_DEFAULT_PACK=enlightened_duck

# Email Channel — Resend
RESEND_API_KEY=your_resend_api_key
EMAIL_DEFAULT_PACK=enlightened_duck

# SMS Channel — Twilio (shares TWILIO_AUTH_TOKEN with WhatsApp)
SMS_DEFAULT_PACK=enlightened_duck

# Discord Channel
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_PUBLIC_KEY=your_discord_app_public_key
DISCORD_DEFAULT_PACK=enlightened_duck

# Slack Channel
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_DEFAULT_PACK=enlightened_duck

# Meta — Messenger + Instagram (shared)
META_PAGE_TOKEN=your_meta_page_access_token
META_VERIFY_TOKEN=tmos13duck
MESSENGER_DEFAULT_PACK=enlightened_duck
INSTAGRAM_DEFAULT_PACK=enlightened_duck

# Web Channel
WEB_DEFAULT_PACK=enlightened_duck

# Web Search (Brave) — free tier: 2000 queries/mo
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Engine
TMOS13_MODEL=claude-sonnet-4-6
TMOS13_PACK=guest
PORT=8000

# Instance Identity (for dedicated deployments)
TMOS13_INSTANCE_NAME=My Instance
TMOS13_VAULT_DIR=./vault

# ── WORLD13 Simulation ──
# Mode: pure = default (all agents converge), shadow = full human spectrum
WORLD13_MODE=pure
WORLD13_MODEL=claude-sonnet-4-5-20250929
WORLD13_DB_PATH=data/world13.db
WORLD13_TICK_SECONDS=30
WORLD13_SESSIONS_PER_TICK=3
WORLD13_API_PORT=8001
