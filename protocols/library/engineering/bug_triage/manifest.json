{
  "id": "bug_triage",
  "name": "Bug Triage Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "engineering",
  "description": "Bug triage intake for engineering teams assessing an incoming defect report. Evaluates severity, reproducibility, impact scope, root cause hypothesis, affected components, and resolution priority to produce a bug triage profile with severity classification and recommended next steps.",
  "base": "library_intake",
  "personality": {
    "tone": "professional, direct",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 14,
    "estimated_turns": "6-10"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
