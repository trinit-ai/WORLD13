{
  "id": "code_review",
  "name": "Code Review Intake",
  "version": "1.0.0",
  "status": "active",
  "access": "public",
  "category": "engineering",
  "description": "Code review intake for engineering teams structuring or assessing a code review process. Evaluates the change scope, review criteria, reviewer qualification, feedback quality, and process health to produce a code review profile with findings and recommendations.",
  "base": "library_intake",
  "personality": {
    "tone": "professional, direct",
    "warmth": 0.5,
    "humor": 0.0,
    "formality": 0.7
  },
  "cartridges": [],
  "commands": {
    "session": {
      "reset": {
        "pattern": "^(reset|start over|restart|new session|clear)$",
        "action": "reset_session"
      },
      "status": {
        "pattern": "^(status|progress|where am i|summary)$",
        "action": "show_status"
      }
    }
  },
  "features": {
    "session_intelligence": true,
    "contact_collection": true,
    "deliverables_pipeline": false,
    "session_journal": true,
    "depth_tracking": true
  },
  "session_policy": {
    "type": "metered",
    "free_turns": 14,
    "estimated_turns": "6-10"
  },
  "privacy": {
    "disclosure": "A summary of this session will be available for review.",
    "data_tier": "standard_intake",
    "transcript_available": true
  }
}
