{
  "id": "manda_negotiation",
  "access": "paid",
  "tier_gate": "V7",
  "name": "Strategy Room",
  "version": "1.1.0",
  "description": "Pressure-test any high-stakes decision. Scenario modeling, negotiation prep, risk analysis, and strategy briefs — for deals, partnerships, launches, or pivots.",
  "tagline": "Pressure-test every decision.",
  "philosophy": "Every high-stakes decision deserves a stress test. The Strategy Room helps you model scenarios, anticipate pushback, quantify risk, and walk into the room with a plan — whether it's a deal, a launch, a pivot, or a difficult conversation.",
  "category": "scenarios",
  "icon": "🎯",
  "base": "strategic_simulation",
  "assembly_mode": "assembled",

  "personality": {
    "tone": "sharp, analytical, direct, constructive",
    "warmth": 0.4,
    "humor": 0.1,
    "formality": 0.7,
    "identity_name": "Strategist",
    "identity_description": "A strategic advisor that pressure-tests decisions, builds scenarios, and helps you think through high-stakes moves before you make them"
  },

  "cartridges": [
    { "id": "briefing", "name": "Decision Framework", "description": "Define the decision, the stakes, and the players. System builds the strategic scenario.", "protocol": "briefing.md" },
    { "id": "negotiation", "name": "Scenario Builder", "description": "Model outcomes, test assumptions, and explore what-if branches for your strategy.", "protocol": "negotiation.md" },
    { "id": "due_diligence", "name": "Negotiation Prep", "description": "Prepare for the conversation — anticipate objections, map leverage, plan your moves.", "protocol": "due_diligence.md" },
    { "id": "board_room", "name": "Risk Analysis", "description": "Stress-test your plan — surface blind spots, quantify downside, and build contingencies.", "protocol": "board_room.md" },
    { "id": "debrief", "name": "Strategy Brief", "description": "Structured output — decision summary, scenario analysis, risk matrix, and recommended path.", "protocol": "debrief.md" },
    { "id": "company_profile", "name": "Company Profile", "description": "Your business identity, hours, contact info, FAQs, disclaimers, and policies — automatically woven into every interaction.", "passive": true }
  ],

  "commands": {
    "session": {
      "reset": { "pattern": "^(reset|start over|restart|new deal|clear)$", "action": "reset_session" },
      "menu": { "pattern": "^(menu|help|options|commands|back)$", "action": "show_menu" },
      "status": { "pattern": "^(status|position|terms|board|deal status|where are we|summary)$", "action": "show_status" },
      "branch": { "pattern": "^(what if|alternative|other option|branch|fork|explore|counter)$", "action": "explore_branch" },
      "debrief": { "pattern": "^(debrief|analysis|review|assess|score|how did I do|close)$", "action": "enter_debrief" },
      "transcript": { "pattern": "^(transcript|download|export|save|deal memo)$", "action": "show_transcript" }
    },
    "navigation": {
      "negotiation": { "pattern": "(offer|propose|counter|terms|price|valuation|structure|bid|negotiate|LOI)", "cartridge": "negotiation" },
      "due_diligence": { "pattern": "(diligence|investigate|financials|audit|risk|contracts|IP|customers|liabilities|data room)", "cartridge": "due_diligence" },
      "board_room": { "pattern": "(board|shareholders|vote|approval|management|communicate|announce|regulatory|antitrust|HSR)", "cartridge": "board_room" }
    }
  },

  "system_screens": { "boot": "boot.md", "menu": "menu.md" },

  "features": {
    "session_intelligence": true,
    "dual_state": true,
    "persona_engine": true,
    "branching_tree": true,
    "outcome_scoring": true,
    "counterfactual_analysis": true,
    "contact_collection": false,
    "transcript_export": true,
    "depth_tracking": true,
    "mood_resonance": true,
    "cross_module_memory": true,
    "vault_rag": true,
    "multi_pack_session": true,
    "session_journal": true
  },

  "delivery": {
    "default_mode": "staged",
    "allowed_recipients": ["email", "internal"],
    "require_approval_for_ai_sessions": true
  },

  "privacy": {
    "disclosure": "Strategic simulation for deal preparation. Scenario inputs used only to generate simulation.",
    "data_tier": "session_only",
    "transcript_available": true,
    "retention_days": 90
  },

  "notifications": {},

  "settings": {
    "difficulty": { "default": "balanced", "options": ["guided", "balanced", "adversarial", "adaptive"] },
    "persona_realism": { "default": "realistic", "options": ["cooperative", "realistic", "aggressive"] },
    "branching_mode": { "default": "interactive", "options": ["linear", "interactive", "exhaustive"] },
    "response_depth": { "default": "detailed", "options": ["concise", "balanced", "detailed"] },
    "deal_complexity": { "default": "standard", "options": ["simple", "standard", "complex", "hostile"] }
  },

  "state": {
    "session": {
      "phase": null,
      "outcome": null,
      "turn_count": 0,
      "active_cartridge": null,
      "depth": 0,
      "mode": "simulation",
      "difficulty": "balanced",
      "branches_explored": 0,
      "current_branch": "main"
    },
    "scenario": {
