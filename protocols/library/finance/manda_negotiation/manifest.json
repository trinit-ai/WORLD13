      "value_left_on_table": null
    }
  },

  "theme": {
    "accent": "#DC2626",
    "surface": "#0D0B09",
    "text": "#E5E2DC"
  },

  "transcript": {
    "format": "markdown",
    "include_metadata": true,
    "include_summary": true,
    "include_scoring": true,
    "include_decision_tree": true,
    "include_counterfactuals": true,
    "include_term_sheet_evolution": true,
    "download_label": "Download Deal Analysis"
  },

  "battle": {
    "enabled": true,
    "domain_type": "financial",
    "default_authority": {
      "max_concession_value": null,
      "auto_authorize_moves": ["assert", "counter", "request", "propose", "confirm", "concede"],
      "trainer_required_moves": ["withdraw", "switch", "use_item", "run", "anchor"],
      "escalate_if": {
        "concession_exceeds_boundary": true,
        "protected_information_requested": true
      }
    },
    "pp_overrides": {
      "anchor": 2,
      "escalate": 2
    },
    "stall_threshold": 3,
    "max_turns": 40,
    "move_instructions": "When engaged in a negotiation battle, select your move type carefully. Use [MOVE:type] marker at the start of each response."
  },

  "data_rail": {
    "tabs": [
      {
        "id": "auth",
        "label": "Auth",
        "icon": "key",
        "type": "infrastructure"
      },
      {
        "id": "pricing",
        "label": "Pricing",
        "icon": "sparkles",
        "type": "infrastructure"
      },
      {
        "id": "deal_info",
        "label": "Deal Info",
        "icon": "Handshake",
        "type": "pack",
        "title": "Deal Information",
        "description": "Captured securely. Encrypted at rest. Never sent to AI.",
        "submit_label": "Save to Vault",
        "success_message": "Deal info saved.",
        "endpoint": "/api/datarail/submit",
        "fields": [
          { "id": "contact_name", "type": "text", "label": "Contact Name", "placeholder": "Full name", "required": true, "pii": true },
          { "id": "contact_email", "type": "email", "label": "Email", "placeholder": "you@example.com", "required": true, "pii": true },
          { "id": "deal_type", "type": "select", "label": "Deal Type", "required": true, "options": ["Acquisition", "Merger", "Joint Venture", "Partnership", "Divestiture", "Other"] },
          { "id": "deal_stage", "type": "select", "label": "Stage", "required": false, "options": ["Preliminary", "LOI", "Due Diligence", "Negotiation", "Closing"] },
          { "id": "estimated_value", "type": "text", "label": "Estimated Value", "placeholder": "Deal size or range", "required": false, "pii": false },
          { "id": "confidentiality", "type": "select", "label": "Confidentiality", "required": false, "options": ["Standard", "High", "Maximum"] }
        ]
      }
    ]
  },

  "library": {
    "visible": true,
    "category": "strategy",
    "tags": ["scenario", "compose", "negotiation"],
    "description": "Stress-test any high-stakes decision against AI counterparties. Scenario modeling, negotiation prep, risk analysis, and strategy briefs for deals, partnerships, or pivots.",
    "author": "TMOS13",
    "license": "included",
    "verb_type": "scenario",
    "industry_tags": ["consulting", "finance", "management"],
    "icon_url": null,
    "price": {
      "model": "included",
      "tier_minimum": null
    }
  }
}
