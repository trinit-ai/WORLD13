{
  "id": "clinical_decision",
  "access": "paid",
  "tier_gate": "S1",
  "name": "Patient Intake",
  "version": "1.1.0",
  "description": "AI-powered patient intake that captures symptoms, collects history, triages urgency, routes to the right specialist, and produces a structured intake summary — before the patient ever sees a provider.",
  "tagline": "Your front desk, always on.",
  "philosophy": "The waiting room is where care begins. A good intake captures what matters, asks the right follow-ups, and gets the patient to the right provider — fast, thorough, and human. This is your always-on front desk.",
  "category": "scenarios",
  "icon": "🩺",
  "base": "strategic_simulation",
  "assembly_mode": "assembled",
  "citations": true,

  "personality": {
    "tone": "empathetic, professional, thorough, calm",
    "warmth": 0.8,
    "humor": 0.05,
    "formality": 0.6,
    "identity_name": "Intake",
    "identity_description": "AI-powered patient intake specialist that captures symptoms, collects history, triages urgency, and routes to the right provider"
  },

  "cartridges": [
    { "id": "briefing", "name": "Symptom Capture", "number": 1, "description": "Collect the patient's chief complaint, symptom timeline, severity, and any immediate red flags.", "file": "briefing.md" },
    { "id": "encounter", "name": "History Collection", "number": 2, "description": "Gather medical history, medications, allergies, social factors, and family history — conversationally, not as a form.", "file": "encounter.md" },
    { "id": "diagnosis", "name": "Urgency Triage", "number": 3, "description": "Assess urgency level, flag time-sensitive conditions, and determine whether the patient needs immediate, same-day, or routine care.", "file": "diagnosis.md" },
    { "id": "treatment", "name": "Specialist Routing", "number": 4, "description": "Match the patient's presentation to the right provider, specialty, or department — with context for the receiving clinician.", "file": "treatment.md" },
    { "id": "debrief", "name": "Intake Summary", "number": 5, "description": "Produce a structured intake summary with demographics, symptoms, history, triage level, and routing recommendation.", "file": "debrief.md" },
    { "id": "company_profile", "name": "Company Profile", "description": "Your business identity, hours, contact info, FAQs, disclaimers, and policies — automatically woven into every interaction.", "passive": true }
  ],

  "commands": {
    "session": {
      "reset": { "pattern": "^(reset|start over|restart|new case|new patient|clear)$", "action": "reset_session" },
      "menu": { "pattern": "^(menu|help|options|commands|back)$", "action": "show_menu" },
      "status": { "pattern": "^(status|summary|chart|vitals|labs|results|findings)$", "action": "show_status" },
      "branch": { "pattern": "^(what if|alternative|other diagnosis|branch|explore)$", "action": "explore_branch" },
      "debrief": { "pattern": "^(debrief|analysis|review|score|how did I do|case review)$", "action": "enter_debrief" },
      "transcript": { "pattern": "^(transcript|download|export|save|case report)$", "action": "show_transcript" }
    },
    "navigation": {
      "encounter": {
        "pattern": "(history|ask|tell me|symptoms|when did|how long|pain|describe|review of systems|social|family|past medical|medications|allergies|exam|examine|auscultate|palpate|inspect|vitals)",
        "cartridge": "encounter"
      },
      "diagnosis": {
        "pattern": "(differential|diagnos|test|order|labs|imaging|CT|MRI|xray|x-ray|blood|CBC|CMP|EKG|ECG|echo|ultrasound|biopsy|culture|results|interpret|rule out|workup)",
        "cartridge": "diagnosis"
      },
      "treatment": {
        "pattern": "(treat|prescribe|medication|dose|therapy|refer|surgery|procedure|admit|discharge|follow up|plan|management|intervention|counsel|educate)",
        "cartridge": "treatment"
      }
    }
  },

  "system_screens": { "boot": "boot.md", "menu": "menu.md" },

  "features": {
    "session_intelligence": true,
    "dual_state": true,
    "persona_engine": true,
    "branching_tree": true,
    "outcome_scoring": true,
    "counterfactual_analysis": true,
    "contact_collection": false,
    "transcript_export": true,
    "depth_tracking": true,
    "mood_resonance": true,
    "cross_module_memory": true,
    "vault_rag": true,
    "multi_pack_session": true,
    "session_journal": true
  },

  "delivery": {
    "default_mode": "staged",
    "allowed_recipients": ["email", "internal"],
    "require_approval_for_ai_sessions": true
  },

  "privacy": {
    "disclosure": "This is a clinical education simulation. No real patient data is used or collected. Not a substitute for medical training or clinical judgment.",
    "data_tier": "session_only",
    "transcript_available": true,
    "retention_days": 90
  },

  "notifications": {},

  "settings": {
    "difficulty": {
      "default": "balanced",
      "options": ["guided", "balanced", "challenging", "adaptive"]
    },
    "patient_realism": {
      "default": "realistic",
      "options": ["cooperative", "realistic", "difficult"]
    },
    "branching_mode": {
      "default": "interactive",
      "options": ["linear", "interactive", "exhaustive"]
    },
    "specialty_focus": {
      "default": "general",
      "options": ["general", "emergency", "internal_medicine", "surgery", "psychiatry", "pediatrics", "ob_gyn"]
    },
    "clinical_setting": {
      "default": "outpatient",
      "options": ["outpatient", "emergency", "inpatient", "icu", "telehealth"]
    }
  },

