          { "id": "date_of_birth", "type": "date", "label": "Date of Birth", "required": false, "pii": true },
          { "id": "visit_reason", "type": "select", "label": "Reason for Visit", "required": true, "options": ["New Symptoms", "Follow-Up", "Annual Physical", "Urgent Concern", "Referral"] },
          { "id": "chief_complaint", "type": "text", "label": "Chief Complaint", "placeholder": "Describe the primary concern in a few words", "required": false, "pii": false }
